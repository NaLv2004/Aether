@article{guo2026cell,
  title={Cell-free massive MIMO signal detector fused with multi-head attention by graph neural network},
  author={Guo, Shihao and Zhang, Xiaohui and Zhang, Gaoyuan},
  journal={Physical Communication},
  year={2026},
  abstract={}
}

